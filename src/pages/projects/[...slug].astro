---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fmtDate } from '../../lib/rubricas';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <p><a href="/projects">← Projects</a></p>
  <h1>{entry.data.title}</h1>
  <p class="date">{fmtDate(entry.data.date)}</p>
  {entry.data.url && (
    <p><a href={entry.data.url}>{entry.data.url}</a></p>
  )}
  <Content />
</BaseLayout>
